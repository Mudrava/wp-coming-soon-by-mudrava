{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mudrava/countdown",
  "version": "1.0.0",
  "title": "Countdown Timer",
  "category": "widgets",
  "icon": "clock",
  "description": "Display a countdown timer to your launch date.",
  "textdomain": "wp-coming-soon-by-mudrava",
  "attributes": {
    "targetDate": {
      "type": "string",
      "default": ""
    },
    "showDays": {
      "type": "boolean",
      "default": true
    },
    "showHours": {
      "type": "boolean",
      "default": true
    },
    "showMinutes": {
      "type": "boolean",
      "default": true
    },
    "showSeconds": {
      "type": "boolean",
      "default": true
    },
    "labelDays": {
      "type": "string",
      "default": "Days"
    },
    "labelHours": {
      "type": "string",
      "default": "Hours"
    },
    "labelMinutes": {
      "type": "string",
      "default": "Minutes"
    },
    "labelSeconds": {
      "type": "string",
      "default": "Seconds"
    },
    "expiredMessage": {
      "type": "string",
      "default": "We have launched!"
    }
  },
  "supports": {
    "html": false,
    "color": {
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "align": true
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}